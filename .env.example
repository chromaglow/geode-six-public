# Geode Six — Environment Variables
# Copy this file to .env and fill in values for your deployment

# Ollama
OLLAMA_HOST=http://localhost:11434

# GCA Document Storage
GCA_ROOT=/mnt/nvme/gca

# Chroma Vector DB
CHROMA_PATH=/mnt/nvme/chroma

# Logging
LOG_PATH=/mnt/nvme/logs

# USB Backup
USB_BACKUP_PATH=/mnt/usb-backup/gca

# RAM threshold (MB) — below this, /query returns "system busy"
RAM_THRESHOLD_MB=1024

# Optional cloud fallback keys (leave blank if not needed)
CLAUDE_API_KEY=
OPENAI_API_KEY=

# Default user for API requests. Usually 'admin' for a single-user setup.
DEFAULT_USER=admin
