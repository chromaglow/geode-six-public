[Unit]
Description=Cloudflare Tunnel for Geode Six
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=[YOUR_LINUX_USER]
ExecStart=/usr/local/bin/cloudflared tunnel run
Restart=on-failure
RestartSec=5
StandardOutput=append:/mnt/nvme/logs/cloudflared.log
StandardError=append:/mnt/nvme/logs/cloudflared.log

[Install]
WantedBy=multi-user.target
